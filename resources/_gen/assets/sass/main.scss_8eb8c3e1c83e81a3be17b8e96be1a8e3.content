:root{--background:#ffffff;--text:#1f2937;--text-muted:#6b7280;--primary:#005a9c;--primary-hover:#00467a;--secondary:#0f766e;--secondary-hover:#115e59;--accent:#d97706;--border:#e5e7eb}*{box-sizing:border-box}html,body{height:100%;margin:0}body{min-height:100vh;display:flex;margin:0;font-family:system-ui,sans-serif;color:var(--text);background:var(--background);line-height:1.6;background-image:linear-gradient(to right,rgba(0,90,156,5%) 1px,transparent 1px),linear-gradient(to bottom,rgba(0,90,156,5%) 1px,transparent 1px);background-size:40px 40px}h1{margin-bottom:0;padding:0 2rem;overflow-wrap:anywhere}h2{margin-top:.5rem;margin-bottom:.5rem;padding:0 2rem}h3{margin-top:.5rem;margin-bottom:.5rem;padding:0 2rem}@media(max-width:768px){h1,h2{padding:0 1rem}}.container{width:95%;max-width:1500px;margin:0 auto}.navbar{max-width:none;width:100%;border-bottom:1px solid var(--border);background:var(--background)}.nav-container{width:100%;margin:0 auto;display:flex;justify-content:space-between;align-items:center;padding:1rem 2rem}.logo{font-weight:700;text-decoration:none;color:var(--primary);font-size:1.5rem}.nav-links{list-style:none;display:flex;gap:1rem;margin:0;padding:0;font-size:1.2rem}.nav-links a{text-decoration:none;color:var(--text)}.nav-links a:hover{color:var(--primary)}@media(max-width:768px){.nav-container{flex-direction:column;align-items:center;padding:.75rem 1rem;gap:.75rem}.logo{font-size:1.4rem}.nav-links{display:flex;flex-wrap:wrap;justify-content:center;gap:.75rem;font-size:1.1rem}}.footer{border-top:1px solid var(--border);padding:.05rem 0;margin-top:auto;text-align:center;color:var(--text-muted);font-size:.9rem;background:var(--background);position:relative;z-index:10}.btn{padding:.9rem 1.4rem;text-decoration:none;border-radius:8px;font-weight:600}.btn-primary{background:var(--primary);color:#fff}.btn-primary:hover{background:var(--primary-hover)}.btn-secondary{border:2px solid var(--primary);color:var(--primary)}.btn-outline{display:inline-block;padding:.5rem 1.2rem;border:2px solid var(--primary);color:var(--primary);border-radius:6px;transition:all .2s ease}.btn-outline:hover{background:var(--primary);color:#fff}.carousel-controls button{padding:.4rem 5rem;border:#000;background:#eee;color:#000;cursor:pointer;border-radius:4px;border:1px solid #000}.carousel-controls{display:flex;justify-content:center;gap:1rem;margin-top:.75rem;border:#000}.carousel-controls button:hover{background:#ddd}.carousel-image-container{position:relative}.carousel-caption{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.75);color:#fff;padding:.75rem;text-align:center;opacity:0;transition:opacity .3s ease}.carousel-image-container:hover .carousel-caption{opacity:1}.social-icons{display:flex;justify-content:center;gap:1.2rem;margin-top:.8rem}.social-icons a{font-size:2.6rem;color:var(--primary);text-decoration:none;transition:color .2s ease}.social-icons a:hover{color:#07f}.about-page .social-icons{justify-content:flex-start}.hero{min-height:75vh;display:flex;flex-direction:column;justify-content:center;padding:1rem 0;text-align:center}.hero h1{color:var(--primary)}.hero-image{width:250px;height:250px;object-fit:cover;border-radius:50%;display:block;margin:0 auto 1rem;align-items:center}.hero-buttons{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap}.subtitle{max-width:700px;margin:0 auto 2rem;color:var(--text-muted)}body{min-height:100vh;display:flex;flex-direction:column}.page-wrapper{flex:1}.hero-image-wrapper{position:relative;width:100vw;height:250px;margin:0 auto 1rem}.hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;object-position:center;z-index:1;opacity:.75}.hero-image{position:relative;z-index:2;width:250px;height:250px;border-radius:50%;object-fit:cover}.book-hero{display:flex;align-items:center;justify-content:space-between;gap:3rem;margin:3rem 0}.book-layout{display:grid;grid-template-columns:1fr 320px;gap:3rem;margin-top:2rem;padding:0 2rem}.book-cover{max-width:300px;width:100%;height:auto}.book-body p{margin-top:0}@media(max-width:768px){.book-layout{display:flex;flex-direction:column;align-items:center}.book-image{order:-1;display:flex;justify-content:center;width:100%}.book-cover{max-width:280px;display:block;margin:0 auto}}.book-cta{margin-top:1.75rem;margin-bottom:1.5rem}.about-layout{display:flex;gap:2rem;padding:0 2rem}.circle-image{width:350px;height:350px;border-radius:50%;object-fit:cover;float:left}.about-image{flex:0 0 350px;display:flex;justify-content:center}.about-text{flex:1}.improvements-image{width:100%;max-width:700px;height:auto;display:block;margin:0 auto;border-radius:8px}html,body{height:100%}@media(max-width:768px){.about-layout{flex-direction:column;align-items:center}.about-image{order:-1;width:100%;display:flex;justify-content:center}.circle-image{float:none;display:block;margin:0 auto 1rem;margin-bottom:-2rem}.about-text{text-align:left;width:100%}}.python-layout{display:flex;gap:2rem;padding:0 2rem;min-width:0}.python-text{flex:1}.python-carousel img{width:100%;max-height:400px;height:auto;object-fit:contain;aspect-ratio:16/9;border-radius:8px}.carousel-controls{display:flex;justify-content:center;gap:1rem}@media(max-width:768px){.python-layout{flex-direction:column;align-items:center}.python-text{width:100%}.python-carousel{order:-1;width:100%;display:flex;flex-direction:column;align-items:center}.python-carousel img{width:100%;max-width:600px}}.bqi-layout{display:flex;gap:1rem;flex-wrap:nowrap;align-items:flex-start;padding:0 2rem}.bqi-text{flex:1}.bqi-carousel{width:665px;flex-shrink:0;margin:0 auto}.bqi-carousel img{width:100%;object-fit:contain;border-radius:8px}@media(max-width:768px){.bqi-layout{flex-direction:column;align-items:center}.bqi-text{width:100%}.bqi-carousel{order:-1;width:100%;display:flex;flex-direction:column;align-items:center;margin-top:1rem}.bqi-carousel img{width:100%;max-width:600px}}